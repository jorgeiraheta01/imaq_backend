DATABASE_URL=postgresql://usuario:password@localhost:5432/imaq_db
SECRET_KEY=cambia-esta-clave-por-una-secreta-y-aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated list of origins allowed by CORS. Restrict to your real
# domains in production — never use "*" once auth.allow_credentials matters.
ALLOWED_ORIGINS=http://localhost:3000

# Resend (https://resend.com) — used to send password-recovery emails.
# Leave RESEND_API_KEY empty in local dev to skip sending silently.
RESEND_API_KEY=
FRONTEND_URL=http://localhost:3000

# Sentry error tracking. Leave empty to disable (skipped silently).
SENTRY_DSN=
